// แก้ไขฟังก์ชัน getSheetData เพื่อรองรับการส่ง Query (Filter)
function getSheetData(sheetName, customQuery = '') {
  // 1. กำหนด Parameter พื้นฐาน (ดึงแค่ column payload)
  let params = '?select=payload';
  
  // 2. ถ้ามีการส่ง Query พิเศษมา (เช่น การกรอง) ให้เอามาต่อท้าย
  if (customQuery) {
    // เช็คว่า customQuery เริ่มต้นด้วย & หรือไม่ ถ้าไม่ให้เติม
    if (!customQuery.startsWith('&')) params += '&';
    params += customQuery;
  }

  // 3. เรียก Supabase พร้อม Filter ที่ส่งมา
  // (ฟังก์ชัน callSupabase ของคุณรองรับ params ตัวที่ 4 อยู่แล้ว)
  const jsonResponse = callSupabase(sheetName.toLowerCase(), 'get', null, params);
  
  // 4. แปลงข้อมูล
  try {
    const data = JSON.parse(jsonResponse);
    if (Array.isArray(data)) {
      return data.map(row => row.payload);
    } else {
      return []; 
    }
  } catch (e) {
    console.error("Error parsing data from " + sheetName + ": " + e.toString());
    return [];
  }
}


function saveDataToSheet(sheetName, id, dataObj) {
  // ⭐ แยกร่าง! ดึงสมอง AI (embedding) ออกมาก่อนเซฟลง payload
  let aiVector = null;
  if (dataObj && dataObj.embedding) {
    aiVector = dataObj.embedding;
    delete dataObj.embedding; // ลบออกจากข้อมูล จะได้ไม่ไปรกใน payload
  }

  const record = {
    id: id.toString(),
    payload: dataObj
  };
  
  // ⭐ เอาสมอง AI ไปหยอดใส่คอลัมน์ embedding แยกต่างหาก
  if (aiVector) {
    record.embedding = aiVector;
  }
  
  const table = sheetName.toLowerCase();
  const url = `${SUPABASE_URL}/rest/v1/${table}`;
  const options = {
    method: 'post',
    headers: {
      'apikey': SUPABASE_ANON_KEY,        
      'Authorization': 'Bearer ' + SUPABASE_KEY, // 🔴 เจาะทะลุ RLS
      'Content-Type': 'application/json',
      'Prefer': 'resolution=merge-duplicates'
    },
    payload: JSON.stringify(record)
  };
  
  UrlFetchApp.fetch(url, options);
  clearAppCache();

  return true;
}


function deleteDataFromSheet(sheetName, id) {
  var encodedId = encodeURIComponent(id);
  callSupabase(sheetName, 'delete', null, `?id=eq.${encodedId}`);
  
  // ⭐ เพิ่มบรรทัดนี้: ล้างความจำทุกครั้งที่มีการลบข้อมูล
  clearAppCache(); 
}
