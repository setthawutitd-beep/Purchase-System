/**
 * ฟังก์ชัน Rollback ระดับ Super Admin (ฉบับแก้ไข: ป้องกัน Rollback ซ้ำซ้อน)
 */
function processSuperAdminRollback(requestId, targetStatus, reason, adminInfo) {
  var lock = LockService.getScriptLock();
  try {
    lock.waitLock(30000);

    // 1. โหลดข้อมูล
    var requests = getSheetData('Requests');
    var inventory = getSheetData('Inventory');
    var assets = getSheetData('Assets');
    
    // ⭐ [แก้ไข] ดึง Logs มาทั้งก้อนแบบเอา id มาด้วย (เพื่อใช้อัปเดตกลับลง Supabase)
    var logsRes = callSupabase('Logs', 'get', null, '?select=id,payload&payload-%3E%3ErelatedRequestId=eq.' + requestId);
    var rawLogs = [];
    try { rawLogs = JSON.parse(logsRes); } catch(e){}

    var reqIndex = requests.findIndex(function(r) { return r.id === requestId; });
    if (reqIndex === -1) throw new Error("ไม่พบเอกสาร ID: " + requestId);
    var req = requests[reqIndex];

    var logsToSave = [];
    var logsToUpdate = []; // ⭐ [NEW] ตัวแปรสำหรับเก็บ Log เดิมที่ต้องแปะป้าย (Reverted)
    
    var inventoryUpdates = new Map(); 
    var assetsToUpdate = new Map();
    var assetsToDelete = new Set(); 

    var dateStr = new Date().toLocaleString('th-TH');

    // -------------------------------------------------------------------------
    // 2. 🔄 PROCESS ROLLBACK BASED ON LOGS
    // -------------------------------------------------------------------------
    
    if (rawLogs && rawLogs.length > 0) {
      rawLogs.forEach(function(row) {
        var log = row.payload;
        // ข้าม Log ที่ถูก Revert ไปแล้ว
        if (log.action.includes('(Reverted)')) return;

        var isProcessed = false;

        // --- A. กรณีรับของเข้า (Stock In) -> ต้องดึงออก ---
        if (log.action.includes('Stock In') && log.assetId) {
           var qty = 0;
           if (log.change.includes('+')) qty = parseInt(log.change.replace('+', ''));
           else if (log.change.includes('Start:')) qty = parseInt(log.change.split(':')[1]);
           
           if (qty > 0) {
               var inv = inventory.find(function(i) { return i.id === log.assetId; });
               if (inv) {
                   var currentInv = inventoryUpdates.get(inv.id) || JSON.parse(JSON.stringify(inv));
                   currentInv.qty = Math.max(0, currentInv.qty - qty);
                   currentInv.lastUpdated = dateStr;
                   inventoryUpdates.set(inv.id, currentInv);

                   logsToSave.push({
                       date: dateStr, action: 'Rollback (Deduct)', item: inv.name, change: '-' + qty,
                       note: 'Rollback: ดึงยอดรับของคืน (Ref Log: ' + log.date + ')',
                       by: adminInfo, relatedRequestId: requestId, assetId: inv.id
                   });
                   isProcessed = true;
               }
           }
        }

        // --- B. กรณีลงทะเบียนทรัพย์สิน (Register Asset) -> ต้องลบทิ้ง ---
        else if ((log.action.includes('Register Asset') || log.action.includes('Add Asset')) && log.assetId) {
            if (log.relatedRequestId === requestId) {
                assetsToDelete.add(log.assetId);
                isProcessed = true;
            }
        }

        // --- C. กรณีเบิกออก (Withdraw) -> ต้องคืนยอดเข้า ---
        else if (log.action.includes('Withdraw') && log.assetId) {
            var qty = 0;
            if (log.change.includes('-')) qty = Math.abs(parseInt(log.change));
            
            if (qty > 0) {
               var inv = inventory.find(function(i) { return i.id === log.assetId; });
               if (inv) {
                   var currentInv = inventoryUpdates.get(inv.id) || JSON.parse(JSON.stringify(inv));
                   currentInv.qty += qty;
                   currentInv.lastUpdated = dateStr;
                   inventoryUpdates.set(inv.id, currentInv);

                   logsToSave.push({
                       date: dateStr, action: 'Rollback (Return)', item: inv.name, change: '+' + qty,
                       note: 'Rollback: คืนยอดเบิกกลับคลัง (Ref Log: ' + log.date + ')',
                       by: adminInfo, relatedRequestId: requestId, assetId: inv.id
                   });
                   isProcessed = true;
               }
            }
        }

        // ⭐⭐⭐ ถ้า Log นี้ถูกดึงยอดไปแล้ว ให้แปะป้าย (Reverted) ป้องกันดึงซ้ำ!
        if (isProcessed) {
            log.action = log.action + ' (Reverted)';
            logsToUpdate.push({ id: row.id, payload: log });
        }
      });
    }

    // -------------------------------------------------------------------------
    // 3. 🧹 FALLBACK CLEANUP (เก็บตก)
    // -------------------------------------------------------------------------
    
    if (['Local', 'HO'].includes(req.type)) {
        var linkedAssets = assets.filter(function(a) { return a.currentRequestId === req.id; });
        linkedAssets.forEach(function(asset) {
            if (!assetsToDelete.has(asset.id)) {
                assetsToDelete.add(asset.id);
            }
        });
    }

    if (req.type === 'Borrow') {
        var borrowedAssets = assets.filter(function(a) { return a.currentRequestId === req.id && a.status === 'Borrowed'; });
        borrowedAssets.forEach(function(asset) {
            if (!assetsToUpdate.has(asset.id)) {
                var updatedAsset = JSON.parse(JSON.stringify(asset));
                updatedAsset.status = 'Available';
                updatedAsset.holder = '-';
                updatedAsset.currentRequestId = null;
                updatedAsset.lastUpdated = dateStr;
                assetsToUpdate.set(asset.id, updatedAsset);

                logsToSave.push({
                    date: dateStr, action: 'Rollback (Free)', item: asset.name, change: 'Status: Available',
                    note: 'Rollback: ยกเลิกการยืม',
                    by: adminInfo, relatedRequestId: requestId, assetId: asset.id
                });
            }
        });
    }

    // -------------------------------------------------------------------------
    // 4. 💾 SAVE CHANGES
    // -------------------------------------------------------------------------

    if (inventoryUpdates.size > 0) {
        var invRecords = [];
        inventoryUpdates.forEach(function(value) { invRecords.push({ id: value.id, payload: value }); });
        var urlInv = SUPABASE_URL + '/rest/v1/inventory';
        var optInv = {
            method: 'post', headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY, 'Content-Type': 'application/json', 'Prefer': 'resolution=merge-duplicates' },
            payload: JSON.stringify(invRecords)
        };
        UrlFetchApp.fetch(urlInv, optInv);
    }

    if (assetsToUpdate.size > 0) {
        var astRecords = [];
        assetsToUpdate.forEach(function(value) { astRecords.push({ id: value.id, payload: value }); });
        var urlAst = SUPABASE_URL + '/rest/v1/assets';
        var optAst = {
            method: 'post', headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY, 'Content-Type': 'application/json', 'Prefer': 'resolution=merge-duplicates' },
            payload: JSON.stringify(astRecords)
        };
        UrlFetchApp.fetch(urlAst, optAst);
    }

    if (assetsToDelete.size > 0) {
        assetsToDelete.forEach(function(assetId) {
            deleteDataFromSheet('Assets', assetId);
        });
        logsToSave.push({
            date: dateStr, action: 'Rollback (Delete)', item: 'Multiple Assets', change: '-' + assetsToDelete.size + ' Items',
            note: 'Rollback: ลบทรัพย์สินที่สร้างจากเอกสารนี้',
            by: adminInfo, relatedRequestId: requestId
        });
    }

    // 5. Manage Request History
    var statusFlow = ['Draft', 'Pending Head', 'Pending PM', 'Pending Check', 'Approved', 'PR Issued', 'PO Issued', 'Ordered', 'Contract Pending', 'Contract Signed', 'Shipping', 'Partially Received', 'Ready to Disburse', 'Completed', 'Received', 'Returned'];
    var targetIdx = statusFlow.indexOf(targetStatus);

    if (req.history) {
        req.history.forEach(function(h) {
            var actionKey = h.action.replace(/ \(.+\)/, '');
            var hIdx = statusFlow.indexOf(actionKey);
            var isFutureStatus = (hIdx > targetIdx);
            var isTransaction = ['Received', 'Completed', 'Partially Received', 'Returned', 'Issued', 'จ่ายของ', 'รับของ'].some(function(k) { return h.action.includes(k); });

            if ((isFutureStatus || isTransaction) && !h.action.includes('(Reverted)')) {
                h.action = h.action + " (Reverted)"; 
            }
        });
    }

    req.history.push({
        date: dateStr, action: 'Rollback to ' + targetStatus, user: adminInfo + ' (Super Admin)',
        note: 'Rollback System: ย้อนสถานะและคืนยอด (อ้างอิง Logs). เหตุผล: ' + reason
    });

    // 6. Reset Request Data
    req.status = targetStatus;
    req.items.forEach(function(item) {
        item.receivedTotal = 0;
        item.receivedLog = [];
    });
    saveDataToSheet('Requests', req.id, req);

    // 7. Save Logs (⭐ อัปเดตทั้ง Log ใหม่ และแก้ไข Log เดิม)
    var allLogRecordsToUpsert = [];
    
    // 7.1 Log ใหม่
    if (logsToSave.length > 0) {
        logsToSave.forEach(function(log) {
             var logId = log.date + '_' + Math.floor(Math.random() * 100000);
             allLogRecordsToUpsert.push({ id: logId, payload: log });
        });
    }
    // 7.2 Log เดิมที่ต้องแปะป้าย (Reverted)
    if (logsToUpdate.length > 0) {
        logsToUpdate.forEach(function(rec) {
             allLogRecordsToUpsert.push(rec);
        });
    }

    if (allLogRecordsToUpsert.length > 0) {
        var urlLog = SUPABASE_URL + '/rest/v1/logs';
        var optLog = {
            method: 'post', headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY, 'Content-Type': 'application/json', 'Prefer': 'resolution=merge-duplicates' },
            payload: JSON.stringify(allLogRecordsToUpsert)
        };
        UrlFetchApp.fetch(urlLog, optLog);
    }

    return { success: true, message: 'Rollback เสร็จสิ้น! ระบบดึงข้อมูลคืนและอัปเดตประวัติเรียบร้อยแล้ว', request: req };

  } catch (e) {
    console.error(e);
    return { success: false, message: 'Rollback Error: ' + e.toString() };
  } finally {
    lock.releaseLock();
  }
}


// --- HELPER: คำนวณยอดคงเหลือ Real-time สำหรับอีเมล (Logic เดียวกับ Frontend) ---
function getStockInfoHtml(itemName, project, currentReqId, allRequests, allInventory, allAssets) {
  let html = '';

  // 1. คำนวณวัสดุ (Inventory)
  // หาสินค้าทั้งหมดที่มีชื่อตรงกันในโครงการ
  const stockItems = allInventory.filter(i => i.name === itemName && i.project === project);
  
  if (stockItems.length > 0) {
    // รวมยอดสต็อกจริง
    const totalStock = stockItems.reduce((sum, i) => sum + i.qty, 0);
    const unitLabel = stockItems[0].unit;

    // คำนวณยอดจอง (Reserved) จากใบเบิกอื่น (Withdraw) ที่ยังไม่จบ
    const reservedQty = allRequests.filter(r => 
      r.job === project && 
      r.type === 'Withdraw' &&
      !['Draft', 'Completed', 'Rejected', 'Returned', 'Cancelled'].includes(r.status) &&
      r.id !== currentReqId
    ).reduce((sum, req) => {
      if (!req.items) return sum;
      const match = req.items.find(i => i.name === itemName);
      return sum + (match ? (match.qty || 0) : 0);
    }, 0);

    // ยอดพร้อมเบิก
    const available = Math.max(0, totalStock - reservedQty);

    html += `<span style="font-size:10px; color:#00796b; background-color:#e0f2f1; padding:2px 5px; border-radius:4px; display:inline-block; margin-right:4px; border:1px solid #b2dfdb;">
               ในคลัง: <b>${available}</b> ${unitLabel}
               ${reservedQty > 0 ? `<span style="color:#ef6c00;">(จอง ${reservedQty})</span>` : ''}
             </span>`;
  }

  // 2. คำนวณทรัพย์สิน (Assets)
  // นับทรัพย์สินที่สถานะ "ว่าง"
  const availableAssetsCount = allAssets.filter(a => 
    a.name === itemName && 
    a.project === project && 
    a.status === 'Available'
  ).length;

  // นับทรัพย์สินที่กำลัง "รออนุมัติยืม" (Borrow Pending)
  const pendingBorrowCount = allRequests.filter(r => 
    r.job === project && 
    r.type === 'Borrow' && 
    !['Draft', 'Completed', 'Rejected', 'Returned', 'Cancelled'].includes(r.status) &&
    r.id !== currentReqId
  ).reduce((sum, req) => {
    if (!req.items) return sum;
    const count = req.items.filter(i => i.name === itemName).length;
    return sum + count;
  }, 0);

  // ยอดว่างจริง
  const netAvailableAssets = Math.max(0, availableAssetsCount - pendingBorrowCount);

  if (netAvailableAssets > 0 || pendingBorrowCount > 0) {
    html += `<span style="font-size:10px; color:#283593; background-color:#e8eaf6; padding:2px 5px; border-radius:4px; display:inline-block; border:1px solid #c5cae9;">
               ว่าง: <b>${netAvailableAssets}</b>
               ${pendingBorrowCount > 0 ? `<span style="color:#ef6c00;">(รอคิว ${pendingBorrowCount})</span>` : ''}
             </span>`;
  }

  return html;
}




