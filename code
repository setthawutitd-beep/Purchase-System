// ... existing code ...
function updateStatusSecurely(id, newStatus, logObj, extraUpdates = {}) {
  // 1. เริ่มระบบล็อก (รอคิวได้นานสุด 15 วินาที)
  var lock = LockService.getScriptLock();
  try {
    lock.waitLock(15000); 
  } catch (e) {
    return { success: false, message: 'ระบบกำลังทำงานหนัก กรุณาลองใหม่อีกครั้ง (Server Busy)' };
  }

  try {
    // 2. ดึงข้อมูลล่าสุดจาก Database
    var requests = getSheetData('Requests');
    var index = requests.findIndex(function(r) { return r.id === id; });
    if (index === -1) return { success: false, message: 'ไม่พบข้อมูลเอกสารนี้ในระบบ' };
    
    var req = requests[index];

    // 3. อัปเดตข้อมูล (สถานะ)
    req.status = newStatus;

    // ⭐ [แก้ไข] สร้างตัวแปรเก็บสถานะไว้ก่อน (Flag) ว่าต้องการสร้างเลขใหม่หรือไม่
    var shouldGenNewDoc = false;

    if (extraUpdates) {
      // ถ้ามีการส่ง docNumber: null มา 
      if (extraUpdates.hasOwnProperty('docNumber') && extraUpdates.docNumber === null) {
          req.docNumber = null; // ล้างเลขเดิม
          shouldGenNewDoc = true; // ✅ จำสถานะไว้ว่าต้องสร้างใหม่
          
          delete extraUpdates.docNumber; // ลบออกจาก object เพื่อไม่ให้ loop เอาค่า null มาทับ
      }

      // อัปเดตค่าอื่นๆ ตามปกติ (เช่น type: 'HO')
      Object.keys(extraUpdates).forEach(function(key) {
        req[key] = extraUpdates[key];
      });
    }

    // 4. บันทึกประวัติ (History)
    if (!req.history) req.history = [];
    if (!logObj.date) logObj.date = new Date().toLocaleString('th-TH');
    req.history.push(logObj);

    // 5. Generate Doc ID Logic
    if (!req.docNumber) {
        var isBuyReady = ['Local', 'HO'].includes(req.type) && 
            ['Approved', 'Revise Needed', 'Ordered', 'PR Issued', 'PO Issued', 'Contract Pending', 'Contract Signed', 'Shipping', 'Completed'].includes(newStatus);
        
        var isUseReady = ['Withdraw', 'Borrow'].includes(req.type) && 
            ['Ready to Disburse', 'Completed', 'Returned'].includes(newStatus);
        
        // ⭐ [แก้ไข] ใช้ตัวแปร shouldGenNewDoc ที่เราเก็บไว้ตอนแรก แทนการเช็คจาก extraUpdates ซ้ำ
        var isForceGen = shouldGenNewDoc;

        if (isBuyReady || isUseReady || isForceGen) {
            // นับเลขล่าสุดจากฐานข้อมูลโดยตรง
            var count = getNextDocIndex(requests, req.type, req.purchaseType);
            var newDocId = generateDocId(req.type, count, req.purchaseType);
            
            req.docNumber = newDocId; 
            
            // อัปเดต Log ให้รู้ว่าเปลี่ยนเลขแล้ว
            if (req.history.length > 0) {
                req.history[req.history.length - 1].note += ' (New Doc No: ' + newDocId + ')';
            }
        }
    }

    // 6. บันทึกข้อมูลลง Supabase
    saveDataToSheet('Requests', req.id, req);

 // 7. จัดการส่งอีเมล (แยก Logic มาจาก syncRequest เดิม)
    /* 🔴 [STOPPED] หยุดการส่งเมลแจ้งเตือนทั่วไป 
       (เพื่อให้การกดเปลี่ยนสถานะหน้าเว็บเร็วขึ้น หรือป้องกันเมลรบกวน) ... */
       
// ⭐ [ปลดล็อก] ยอมให้ส่งอีเมล "เฉพาะ" กรณีที่ตีกลับให้แก้ไข หรือไม่อนุมัติ (เพื่อให้ผู้ขอรู้ตัวทันที)
    if (newStatus === 'Revise Needed' || newStatus === 'Rejected') {
        try {
            handleStatusNotification(req);
        } catch (err) {
            console.error("Email Error: " + err);
        }
    }

    // ⭐⭐⭐ เพิ่มโค้ดดักส่ง LINE ตรงนี้ ⭐⭐⭐
    try {
        sendLineGroupNotification(req);
    } catch (err) {
        console.error("LINE Error: " + err);
    }

    return { success: true, request: req };
} catch (e) {
    return { success: false, message: 'Error: ' + e.toString() };
  } finally {
    // 8. ปลดล็อกเสมอ เพื่อให้คนอื่นใช้งานต่อได้
    lock.releaseLock();
  }
}


