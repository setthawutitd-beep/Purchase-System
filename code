// ⭐ ระบบ Cache ของ Google (รองรับข้อมูลขนาดใหญ่)
// ==========================================
function getCachedData(key) {
  const cache = CacheService.getScriptCache();
  const chunks = cache.get(key + '_CHUNKS');
  if (!chunks) return null;
  
  let stringData = '';
  for (let i = 0; i < parseInt(chunks); i++) {
    const chunk = cache.get(key + '_' + i);
    if (!chunk) return null; // ถ้าชิ้นส่วนหาย ให้ถือว่า Cache เสีย
    stringData += chunk;
  }
  return stringData;
}

function setCachedData(key, stringData, expirationInSeconds) {
  const cache = CacheService.getScriptCache();
  const chunkSize = 45000; // ตัดแบ่งก้อนละ 45,000 ตัวอักษร (ป้องกันเกิน Limit 100KB ของ Google)
  const chunks = Math.ceil(stringData.length / chunkSize);
  
  if (chunks > 30) return; // ถ้าข้อมูลใหญ่เกินไป ไม่ต้องจำ
  
  cache.put(key + '_CHUNKS', chunks.toString(), expirationInSeconds);
  for (let i = 0; i < chunks; i++) {
    cache.put(key + '_' + i, stringData.substring(i * chunkSize, (i + 1) * chunkSize), expirationInSeconds);
  }
}

function clearAppCache() {
  const cache = CacheService.getScriptCache();
  cache.remove('ALL_APP_DATA_CHUNKS');
  for(let i=0; i<30; i++) {
    cache.remove('ALL_APP_DATA_' + i);
  }
}


