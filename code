function createRequestSecurely(reqData) {
  var lock = LockService.getScriptLock();
  try {
    // 1. เริ่มล็อกระบบ (รอคิวได้นานสุด 30 วินาที)
    lock.waitLock(30000); 
    
    // 2. ดึงข้อมูล Requests ล่าสุดจาก Database (Refresh ข้อมูลจริง)
    var allRequests = getSheetData('Requests');

    // =========================================================
    // 🟢 2.5 [เพิ่มใหม่] เช็คสต็อก/สถานะจอง ก่อนทำต่อ
    // ส่ง allRequests ไปด้วยเพื่อช่วยเช็คว่ามีใครจองค้างอยู่ไหม
    var errorMsg = checkAvailability(reqData, allRequests);
    
    if (errorMsg) {
       // ถ้าไม่ว่าง/ไม่พอ ให้หยุดและส่งค่า false กลับไปทันที
       return { success: false, message: errorMsg };
    }
    // =========================================================
    
    // 3. คำนวณหา ID ถัดไป (REQ-xxx)
    var existingIds = allRequests
        .map(function(r) { return r.id; })
        .filter(function(id) { return id && typeof id === 'string' && id.startsWith('REQ-'); });

    var maxNum = 0;
    if (existingIds.length > 0) {
        maxNum = existingIds.reduce(function(max, id) {
            var numPart = parseInt(id.replace(/^REQ-/, ''), 10);
            return !isNaN(numPart) && numPart > max ? numPart : max;
        }, 0);
    }
    
    var nextId = 'REQ-' + String(maxNum + 1).padStart(3, '0');
    
    // 4. กำหนด ID ใหม่ให้กับข้อมูล
    reqData.id = nextId;
    
    // 5. บันทึกลง Database
    saveDataToSheet('Requests', nextId, reqData);
    
    // 6. ส่งอีเมลแจ้งเตือน
    if (reqData.status !== 'Draft') {
        try {
            triggerEmails(reqData);        
            handleStatusNotification(reqData); 
        } catch (emailErr) {
            console.error("Email Error: " + emailErr);
        }
    }
    
    return { success: true, request: reqData };
    
  } catch (e) {
    return { success: false, message: 'บันทึกไม่สำเร็จ: ' + e.toString() };
  } finally {
    // 7. ปลดล็อกเสมอ
    lock.releaseLock();
  }
}

function checkAvailability(newReq, allRequests) {
  var inventory = getSheetData('Inventory'); 
  var assets = getSheetData('Assets');

  for (var i = 0; i < newReq.items.length; i++) {
    var item = newReq.items[i];

    // --- กรณี 1: เบิกวัสดุ (Withdraw) ---
    if (newReq.type === 'Withdraw') {
      // ดึงประเภทที่เลือกว่าเป็น System หรือ NonSystem (ถ้าไม่มีให้ถือเป็น System)
      var itemStockType = item.stockType || newReq.withdrawStockType || 'System';

      // 1. หาของใน Inventory ตาม Project และ StockType ที่เลือก
      var stockItem = inventory.find(function(inv) { 
        return inv.name === item.name && 
               inv.project === newReq.job && 
               (inv.stockType || 'System') === itemStockType;
      });

      if (!stockItem) return 'ไม่พบสินค้า "' + item.name + '" ประเภท "' + (itemStockType === 'System' ? 'ในระบบ' : 'นอกระบบ') + '" ในคลังสินค้า';

      // 2. คำนวณยอดจองรออนุมัติ (แยกตาม Type เดียวกัน)
      var pendingQty = allRequests.filter(function(r) {
        return r.type === 'Withdraw' && 
               r.job === newReq.job &&
               r.status !== 'Completed' && 
               r.status !== 'Rejected' && 
               r.status !== 'Draft' &&
               r.status !== 'Cancelled' &&
               r.id !== newReq.id;
      }).reduce(function(sum, r) {
        var matchItem = r.items ? r.items.find(function(it) { 
            var itType = it.stockType || r.withdrawStockType || 'System';
            return it.name === item.name && itType === itemStockType; 
        }) : null;
        return sum + (matchItem ? Number(matchItem.qty) : 0);
      }, 0);

      // 3. เช็คยอดคงเหลือจริง
      var currentStock = Number(stockItem.qty || 0); 
      var realAvailable = currentStock - pendingQty;

      if (Number(item.qty) > realAvailable) {
        return 'สินค้า "' + item.name + '" มีไม่พอ (คงเหลือว่าง: ' + realAvailable + ', ยอดจอง: ' + pendingQty + ')';
      }
    }

    // --- กรณี 2: ยืมทรัพย์สิน (Borrow) ---
    else if (newReq.type === 'Borrow') {
      if (item.assetId) { 
        var assetObj = assets.find(function(a) { return a.id === item.assetId; }); 
        
        if (!assetObj) return 'ไม่พบรหัสทรัพย์สิน ' + item.assetId;
        if (assetObj.status !== 'Available') return 'ทรัพย์สิน "' + item.name + '" ไม่ว่าง (สถานะ: ' + assetObj.status + ')';

        var isBookedByOther = allRequests.some(function(r) {
           return r.type === 'Borrow' &&
                  !['Completed', 'Rejected', 'Returned', 'Cancelled', 'Draft'].includes(r.status) &&
                  r.id !== newReq.id &&
                  r.items && r.items.some(function(it) { return it.assetId === item.assetId; });
        });

        if (isBookedByOther) return 'ทรัพย์สิน "' + item.name + '" กำลังติดการจองโดยผู้อื่นอยู่';
      }
    }
  }

  return null; 
}

