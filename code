const LINE_ACCESS_TOKEN = PropertiesService.getScriptProperties().getProperty('LINE_ACCESS_TOKEN');
const LINE_GROUP_APPROVE = 'Caddbe38f8930c12f37fc29c5f76861b9'; // กลุ่มรออนุมัติ
const LINE_GROUP_STORE = '';   // กลุ่มสโตร์ (รอตัดจ่าย)

function sendLineGroupNotification(req) {
  let targetGroupId = '';
  let displayStatus = '';
  let headerText = '';

  // 1. ตรวจสอบสถานะเพื่อกำหนดกลุ่มเป้าหมายและข้อความ
  if (req.status === 'Pending Head') {
    targetGroupId = LINE_GROUP_APPROVE;
    headerText = '🔔 มีคำขอใหม่ต้องการการอนุมัติ!';
    
    // แยกชื่อสถานะตามประเภทเอกสาร
    if (req.type === 'Withdraw' || req.type === 'Borrow') {
      displayStatus = 'รออนุมัติ Level 1 / Level 2';
    } else {
      displayStatus = 'รออนุมัติ Level 1';
    }

  } else if (req.status === 'Ready to Disburse') {
    targetGroupId = LINE_GROUP_STORE;
    headerText = '📦 มีรายการรอจ่ายของ / ตัดสต็อก!';
    displayStatus = 'รอจ่ายของ (เบิก/ยืม)';
    
  } else {
    // ถ้านอกเหนือจาก 2 สถานะนี้ จะไม่ส่ง LINE ออกไป
    return;
  }

  // 2. แปลงประเภท (Type) ให้เป็นภาษาไทยเพื่อให้อ่านง่าย
  let displayType = req.type;
  if (req.type === 'Local') displayType = 'สั่งซื้อ Local';
  else if (req.type === 'HO') displayType = req.purchaseType === 'Rent' ? 'สั่งซื้อ HO (เช่า)' : 'สั่งซื้อ HO (ซื้อขาด)';
  else if (req.type === 'Withdraw') displayType = 'เบิกวัสดุ';
  else if (req.type === 'Borrow') displayType = 'ยืมทรัพย์สิน';

  // 3. สรุปรายการสินค้า (แสดงสูงสุด 5 รายการแรก เพื่อไม่ให้ข้อความยาวเกินไป)
  let itemsList = req.items.slice(0, 5).map((item, i) => `  ${i+1}. ${item.name} (${item.qty} ${item.unit})`).join('\n');
  if (req.items.length > 5) {
    itemsList += `\n  ... และอื่นๆ อีก ${req.items.length - 5} รายการ`;
  }
  
  // 4. จัดรูปแบบข้อความที่จะส่ง
  const messageText = `${headerText}\n\n` +
                      `📌 สถานะ: ${displayStatus}\n` +
                      `📄 เลขที่: ${req.docNumber || req.id}\n` +
                      `🏢 โครงการ: ${req.job}\n` +
                      `👤 ผู้ขอ: ${req.requester}\n` +
                      `🏷️ ประเภท: ${displayType}\n` +
                      `\n📦 รายการ:\n${itemsList}\n` +
                      `\n👉 กรุณาเข้าสู่ระบบเพื่อตรวจสอบและดำเนินการครับ`;

  // 5. ข้อมูลสำหรับยิง API
  const url = 'https://api.line.me/v2/bot/message/push';
  const payload = {
    to: targetGroupId,
    messages: [{ type: 'text', text: messageText }]
  };
  
  const options = {
    method: 'post',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + LINE_ACCESS_TOKEN
    },
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  };

  try {
    const res = UrlFetchApp.fetch(url, options);
    console.log("LINE Notify Response: " + res.getContentText());
  } catch (error) {
    console.error("LINE Notify Error: " + error.toString());
  }
}

